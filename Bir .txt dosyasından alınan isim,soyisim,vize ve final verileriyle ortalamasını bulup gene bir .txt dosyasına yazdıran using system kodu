using System;
using System.IO;
using System.Globalization;

class Program
{
    static void Main()
    {
        // Sabit klasör yolu
        string folder = @"C:\Users\Win10\Downloads\fwdalgoritmauygulama";
        string inputPath = Path.Combine(folder, "giris.txt");
        string outputPath = Path.Combine(folder, "cikis.txt");

        // Giriş dosyasının varlığını kontrol et
        if (!File.Exists(inputPath))
        {
            Console.WriteLine($"Hata: '{inputPath}' bulunamadı.");
            return;
        }

        // Satırları oku ve her öğrenci için ortalama hesaplayıp çıkış dosyasına yaz
        var lines = File.ReadAllLines(inputPath);
        using (var writer = new StreamWriter(outputPath))
        {
            foreach (var line in lines)
            {
                if (string.IsNullOrWhiteSpace(line))
                    continue;

                var parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length < 4)
                    continue;

                string ad = parts[0];
                string soyad = parts[1];

                if (!double.TryParse(parts[2], NumberStyles.Any, CultureInfo.InvariantCulture, out double vize) ||
                    !double.TryParse(parts[3], NumberStyles.Any, CultureInfo.InvariantCulture, out double fin))
                    continue;

                double ort = vize * 0.4 + fin * 0.6;
                writer.WriteLine($"{ad} {soyad} {vize} {fin} {ort:0.##}");
            }
        }

        Console.WriteLine($"İşlem tamamlandı. Çıkış dosyası:\n {outputPath}");
    }
}
